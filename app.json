{
  "expo": {
    "name": "Touch Love",
    "slug": "touch-love",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "touchlove",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0A0510"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.touchlove.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "O Touch Love precisa da tua localização para saber quando alguém que gosta de ti está perto.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "package": "com.touchlove.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0510",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O Touch Love precisa da tua localização para saber quando alguém que gosta de ti está perto.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF3B6F"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O Touch Love precisa de acesso às tuas fotos para poderes escolher uma foto de perfil.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-font",
      "expo-audio"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d0694f18-2ea3-41e5-8cfe-74ac91579c1b"
      }
    },
    "owner": "noamecc"
  }
}
